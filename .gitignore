# Armbian build artifacts (inside the submodule, ignored there too — belt and suspenders)
build/cache/
build/output/

# Local scratch
*.img
*.img.xz
*.log
__pycache__/

# Autogenerated by the Armbian framework on first run (delete to regenerate)
userpatches/config-example.conf

# Build-generated artifacts: compiled in the image chroot, never committed
userpatches/overlay/usr/local/lib/*.so
userpatches/overlay/lib/firmware/*.bin

# PICO-8 is proprietary (lexaloffle.com): place your licensed copy here for
# image builds, but it must never be committed. See docs/PICO8.md.
userpatches/overlay/root/pico-8/
