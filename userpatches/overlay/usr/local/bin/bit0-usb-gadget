#!/bin/bash
# Bit0 USB gadget: ADB over the OTG port, like the Luckfox SDK image.
# configfs composite gadget with a single functionfs function running the
# Rockchip/Buildroot adbd binary (see docs/BINARIES.md).
#
# SECURITY: this adbd performs no authentication — any USB host gets a root
# shell. Intended dev posture; opt out by creating /boot/bit0-no-adb.
set -e

if [ -e /boot/bit0-no-adb ]; then
	echo "bit0-usb-gadget: /boot/bit0-no-adb present, adb disabled" >&2
	exit 0
fi

G=/sys/kernel/config/usb_gadget/bit0

modprobe libcomposite
modprobe usb_f_fs

mountpoint -q /sys/kernel/config || mount -t configfs none /sys/kernel/config

if [ ! -d "$G" ]; then
	mkdir -p "$G"
	cd "$G"
	echo 0x2207 > idVendor		# Rockchip: Windows adb driver already matches
	echo 0x0006 > idProduct		# same IDs as the SDK adb gadget
	echo 0x0310 > bcdDevice
	echo 0x0200 > bcdUSB
	mkdir -p strings/0x409
	echo "Bit0"          > strings/0x409/manufacturer
	echo "Bit0 Handheld" > strings/0x409/product
	# Per-unit serial so two devices on one host don't collide in adb:
	# SoC serial from DT, else machine-id, else the old fixed string.
	SERIAL=$(tr -d '\0' < /proc/device-tree/serial-number 2>/dev/null || true)
	[ -n "$SERIAL" ] || SERIAL=$(cut -c1-16 /etc/machine-id 2>/dev/null || true)
	[ -n "$SERIAL" ] || SERIAL="bit0-0001"
	echo "$SERIAL"       > strings/0x409/serialnumber
	mkdir -p configs/b.1/strings/0x409
	echo "adb" > configs/b.1/strings/0x409/configuration
	echo 500   > configs/b.1/MaxPower
	mkdir -p functions/ffs.adb
	ln -sf "$G/functions/ffs.adb" configs/b.1/
fi

mkdir -p /dev/usb-ffs/adb
mountpoint -q /dev/usb-ffs/adb || mount -t functionfs adb /dev/usb-ffs/adb

/usr/local/bin/adbd &
ADBD=$!

# adbd writes its descriptors to ep0; the data endpoints appear when ready.
# Only then may the UDC be bound, or enumeration races and fails.
for _ in $(seq 1 50); do
	[ -e /dev/usb-ffs/adb/ep1 ] && break
	sleep 0.1
done

ls /sys/class/udc | head -1 > "$G/UDC"

wait "$ADBD"
