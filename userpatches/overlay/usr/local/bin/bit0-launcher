#!/usr/bin/env python3
"""Bit-0 boot launcher.

Owns only: startup guards (singleton, SD release, stale-app cleanup),
page construction from the app registry + built-ins, and the input/render
event loop. Widgets/pages/router live in bit0.ui, drawing primitives in
bit0.fb, app launching in bit0.apps, the TOML registry in bit0.registry.

Rendering model (audit 6.2): the loop drains all pending input, updates
state (marking widgets dirty), then composes and flushes at most once per
tick (~30 fps, with a final render when input goes idle). Widgets never
flush themselves; control values (volume/brightness) come from a State
cache, never from sysfs/subprocess in the draw path.

Started at boot by bit0-launcher.service.
"""

import atexit
import os
import sys
import fcntl
import select
import subprocess
import time

sys.path.insert(0, '/usr/local/lib')
from bit0.evdev import (EV_SYN, EV_KEY, EV_REL, EV_ABS,
                        REL_X, REL_Y, ABS_X, ABS_Y, BTN_LEFT, BTN_TOUCH,
                        KEY_ESC, KEY_ENTER, KEY_KPENTER, KEY_BACK, KEY_SPACE,
                        KEY_UP, KEY_DOWN, KEY_LEFT, KEY_RIGHT,
                        EVENT_SIZE, unpack_event, find_event, grab)
from bit0.fb import Screen, fullscreen_message, GLYPH_H
from bit0.apps import (kill_stale, launch_entry, run_terminal, run_calibrate,
                       get_volume, vol_set, vol_state_read,
                       get_brightness, set_brightness)
from bit0.sdspi import run_sdcard, sd_release
from bit0.registry import load_apps
from bit0.ui import theme
from bit0.ui.assets import load_icon, GEAR_FALLBACK, BACK_FALLBACK
from bit0.ui.core import Page, Router
from bit0.ui.mascot import (Mascot, MascotCard, load_mascots,
                            read_selected, save_selected)
from bit0.ui.widgets import Button, LiveLabel, Slider, AppGrid, vstack, hstack

MOUSE_NAME = 'Lyra UART Mouse'
TOUCH_NAME = 'Lyra Touch Mouse'
KBD_NAME = 'Lyra UART Keyboard'
N_KINDS = 3  # mouse + touch + kbd: fewer online -> periodic rescan

FRAME_S = 0.033  # ~30 fps compose/flush cap (the SPI panel link is slow)

# ENTER-like keys never act on autorepeat (no repeat-activation); arrows
# do repeat for hold-to-scrub sliders and menu movement (audit 6.4)
NO_REPEAT = (KEY_ENTER, KEY_KPENTER, KEY_SPACE, KEY_ESC, KEY_BACK)


_devs = {}  # live input fds; module-global so the atexit hook reaches them


def open_inputs():
    """Returns {fd_object: kind} for the pointer + keyboard devices. The
    keyboard is EVIOCGRAB'd: it has a console kbd handler, and without
    the grab every menu keypress would leak to the tty under the UI. The
    grab can never outlive the menu: close_inputs releases it explicitly
    (app launches, atexit), and the kernel drops grabs with the fd on any
    process death - the terminal app depends on the console path."""
    global _devs
    devs = {}
    for name, kind in ((MOUSE_NAME, 'mouse'), (TOUCH_NAME, 'touch'),
                       (KBD_NAME, 'kbd')):
        path = find_event(name)
        if path:
            try:
                f = open(path, 'rb', buffering=0)
                os.set_blocking(f.fileno(), False)
                if kind == 'kbd':
                    try:
                        grab(f, True)
                    except OSError:
                        pass  # ungrabbed keyboard still navigates
                devs[f] = kind
            except OSError:
                pass
    _devs = devs
    return devs


def close_inputs(devs):
    for f, kind in devs.items():
        if kind == 'kbd':
            try:
                grab(f, False)  # explicit: the console gets keys back NOW
            except OSError:
                pass
        try:
            f.close()
        except OSError:
            pass


def splash(scr, th):
    """Boot splash, fully theme-driven (audit 6.3): text/colors/scale/
    duration and an optional logo come from theme.json; duration_s 0
    skips it entirely."""
    if th.splash_duration_s <= 0:
        return
    scr.fill_rect(0, 0, scr.w, scr.h, th.splash_bg_color)
    s = th.splash_font_scale
    th_h = round(GLYPH_H * s)
    logo = load_icon(th.splash_logo) if th.splash_logo else None
    cy = (scr.h - th_h) // 2 - 14
    if logo:
        lw, lh = len(logo[0]), len(logo)
        if not th.splash_text:  # logo only: center it
            ly = (scr.h - lh) // 2
        else:                   # logo above the text block
            ly = max(0, cy - lh - 8)
            cy = ly + lh + 8
        lx = (scr.w - lw) // 2
        for gy, line in enumerate(logo):
            for gx, ch in enumerate(line):
                if ch == '#':
                    scr.fill_rect(lx + gx, ly + gy, 1, 1, th.splash_text_color)
                elif ch == '*':
                    scr.fill_rect(lx + gx, ly + gy, 1, 1, th.splash_bar_color)
    if th.splash_text:
        tw = scr.text_width(th.splash_text, s)
        scr.text(th.splash_text, (scr.w - tw) // 2, cy, s,
                 th.splash_text_color)
        scr.fill_rect((scr.w - tw) // 2, cy + th_h + 14, tw, 4,
                      th.splash_bar_color)
    scr.flush()
    time.sleep(th.splash_duration_s)


def build_pages(scr, state, th):
    """Main menu (registry-driven tile grid) + settings. Control widgets
    read/write the State cache, never sysfs/subprocess in the draw path;
    colors and metrics come from the theme."""

    def vol_step(d):
        base = state['vol'] if state['vol'] is not None else get_volume()
        # optimistic: vol_set returns the clamped pct; the helper runs
        # without blocking so the % label updates on the next frame
        state['vol'] = vol_set(base + d, wait=False)

    def vol_text():
        return '--' if state['vol'] is None else '%d%%' % state['vol']

    def bri_set(pct):
        # cache now; the render tick writes sysfs (at most once per frame)
        # and refreshes the cache with the clamped value before drawing
        state['bri_pending'] = pct

    # main menu: built-ins and TOML registry apps share one entry shape
    entries = [
        {'order': 10, 'label': 'TERMINAL', 'app': run_terminal},
        {'order': 90, 'label': 'SD CARD', 'app': (lambda: run_sdcard(scr))},
    ] + load_apps()
    entries.sort(key=lambda e: (e['order'], e['label']))
    # the mascot strip is reserved on the main page only; the bubble
    # floats above page content and repaints via full recompose
    grid = AppGrid(entries, x=6, y=40, w=scr.w - 12,
                   h=scr.h - th.mascot_strip - 50)
    gear = Button(icon=load_icon('gear.pbm') or GEAR_FALLBACK,
                  action={'push': 'settings'},
                  x=scr.w - 36, y=6, w=30, h=26)
    main = Page('main', 'BIT-0', [grid, gear])

    slider_y, volrow_h = 46, 30
    volrow_y = slider_y + th.slider_h + 18
    slider = Slider('BRIGHTNESS', getter=(lambda: state['bri']),
                    setter=bri_set, x=24, y=slider_y, w=scr.w - 48,
                    h=th.slider_h)
    vol_label = LiveLabel(vol_text)

    def volrow_key(code):
        # focus anywhere on the volume row: LEFT/RIGHT step the volume
        if code not in (KEY_LEFT, KEY_RIGHT):
            return None
        vol_step(-10 if code == KEY_LEFT else 10)
        vol_label.dirty = True
        return True

    vol_minus = Button('VOL -', action={'act': (lambda: vol_step(-10))})
    vol_plus = Button('VOL +', action={'act': (lambda: vol_step(+10))})
    vol_minus.on_key = volrow_key
    vol_plus.on_key = volrow_key
    volrow = hstack([vol_minus, vol_label, vol_plus],
                    x=24, y=volrow_y, w=scr.w - 48, h=volrow_h, gap=8)
    col = vstack([
        Button('CALIBRATE',
               action={'launch': {'label': 'CALIBRATE', 'app': run_calibrate}}),
        Button('RESTART', action={'cmd': [['sync'], ['reboot']],
                                  'msg': 'RESTARTING...'}),
        Button('POWER OFF', action={'cmd': [['sync'], ['poweroff']],
                                    'msg': 'POWERING OFF'})],
        x=(scr.w - th.button_w) // 2, w=th.button_w,
        top=volrow_y + volrow_h + 10, bottom=scr.h - 10,
        max_h=th.button_max_h)
    back = Button(icon=load_icon('back.pbm') or BACK_FALLBACK,
                  action={'pop': True}, x=6, y=6, w=30, h=26)
    settings = Page('settings', 'SETTINGS', [slider] + volrow + col + [back])

    return {'main': main, 'settings': settings}


def page_key(pg, code):
    """Keyboard navigation on a page (audit 6.4): the focused widget's
    hook first (slider scrub, volume step, grid row movement), then the
    focus ring / activate / back. Returns an action dict or None."""
    w = pg.focused()
    if w:
        r = w.on_key(code)
        if isinstance(r, dict):
            return r
        if r:
            return None  # consumed by the widget
    if code in (KEY_UP, KEY_LEFT):
        pg.focus_step(-1)
    elif code in (KEY_DOWN, KEY_RIGHT):
        pg.focus_step(+1)
    elif code in (KEY_ENTER, KEY_KPENTER):
        return w.activate() if w else None
    elif code in (KEY_ESC, KEY_BACK):
        return {'pop': True}
    return None


_lock = None  # must stay open for the process lifetime


def acquire_singleton():
    """Race-free single-instance guard via flock (PID scanning races when
    two respawn loops start children simultaneously - they mutually abort)."""
    global _lock
    _lock = open('/var/run/bit0-launcher.lock', 'w')
    try:
        fcntl.flock(_lock, fcntl.LOCK_EX | fcntl.LOCK_NB)
        return True
    except OSError:
        return False


def main():
    if not acquire_singleton():
        print('bit0-launcher: another instance is running, exiting', flush=True)
        sys.exit(0)
    # Keep the SPI SD card unbound by default so it doesn't poll the shared bus
    # and freeze the display; the SD CARD menu binds it on demand.
    sd_release()
    # Clear any app orphaned by a previous launcher restart still holding the
    # single-stream audio amp (would mute the next launch).
    kill_stale('pico8_dyn')
    # keep fbcon from blinking its cursor over our pixels
    try:
        with open('/sys/class/graphics/fbcon/cursor_blink', 'w') as f:
            f.write('0')
    except OSError:
        pass
    try:
        with open('/dev/tty1', 'w') as t:
            t.write('\033[?25l\033[2J')
    except OSError:
        pass

    th = theme.load()
    scr = Screen()
    scr.set_cursor(load_icon('cursor.pgm'))  # None keeps the built-in arrow
    # splash only on the first start after boot (/tmp is tmpfs); respawns
    # and manual restarts go straight to the menu
    first_boot = not os.path.exists('/tmp/.bit0-splash-shown')
    if first_boot:
        splash(scr, th)
        open('/tmp/.bit0-splash-shown', 'w').close()

    # Value cache: widgets draw from here, never from sysfs/subprocess.
    # vol is None until first read (on settings-page entry).
    state = {'vol': None, 'vol_mtime': None,
             'bri': get_brightness(), 'bri_pending': None}
    pages = build_pages(scr, state, th)
    mascot = None
    if th.mascot_enabled:
        pool = load_mascots()
        sel = next((m for m in pool if m['id'] == read_selected()), None)
        box = th.mascot_strip - 6
        mascot = Mascot(sel or pool[0],
                        x=scr.w - box - 4, y=scr.h - box - 4, w=box, h=box)
        pages['main'].widgets.append(mascot)  # last in the reserved band
        if sel is None:
            # first boot (or wiped state): pick a companion; the card's
            # action persists the choice and pops back to main
            cw, chh, gap = 110, 150, 24
            x0 = (scr.w - 2 * cw - gap) // 2
            cards = [MascotCard(m, x=x0 + i * (cw + gap), y=48,
                                w=cw, h=chh) for i, m in enumerate(pool[:2])]
            pages['choose'] = Page('choose', 'CHOOSE YOUR MASCOT', cards)
    router = Router(pages, root='main', overlay=mascot)
    if mascot and 'choose' in pages:
        router.push('choose')
    elif mascot and first_boot and th.mascot_greeting:
        mascot.say(list(th.mascot_greeting))

    cx, cy = scr.w // 2, scr.h // 2
    devs = open_inputs()
    atexit.register(lambda: close_inputs(_devs))  # kbd grab dies with us
    print(f'bit0-launcher: inputs: {sorted(devs.values())}', flush=True)

    full = True           # full-page recompose pending
    cursor_dirty = False  # pointer moved / cursor visibility changed
    cursor_on = True      # hidden after keyboard use, back on pointer motion
    last_render = 0.0
    scr._last_cur = (cx, cy)

    def render():
        """Single flush point per tick: apply deferred sysfs writes, compose
        dirty widgets, flush their rects (or the whole page), cursor last."""
        nonlocal full, cursor_dirty, last_render
        pg = router.page
        if state['bri_pending'] is not None:
            state['bri'] = set_brightness(state['bri_pending'])
            state['bri_pending'] = None
        dirty = pg.dirty_widgets()
        if not full and router.overlay and router.overlay.bubble_visible \
                and any(w is not router.overlay for w in dirty):
            # a widget under the floating bubble changed: recompose the
            # whole scene so draw order stays bubble-on-top
            full = True
        if full:
            pg.compose(scr)
            scr.flush()  # full-frame flush covers the old cursor patch too
        else:
            scr.erase_cursor(*scr._last_cur)
            for i, w in enumerate(pg.widgets):
                if w.dirty:
                    w.draw(scr, i == pg.focus)
                    for rect in w.flush_rects():
                        scr.flush(*rect)
                    w.dirty = False
        if cursor_on:
            scr.draw_cursor(cx, cy)
            scr._last_cur = (cx, cy)
        full = False
        cursor_dirty = False
        last_render = time.monotonic()

    render()

    ax = ay = None  # latest absolute touch sample
    pend = {'mouse': False, 'touch': False}  # button-down awaiting SYN
    held = False    # pointer button currently down (for slider drag)
    last_input = time.monotonic()
    while True:
        if not devs:  # nothing to read - retry discovery
            time.sleep(1)
            devs = open_inputs()
            continue

        # select timeout = next scheduled deadline: the remaining frame
        # budget when a render is pending; on the settings page a 0.5 s
        # poll of the bit0-vol state file (hotkey volume changes never
        # reach us as input events); else the 5 s rescan idle.
        pg = router.page
        pending = full or cursor_dirty or pg.dirty_widgets() \
            or state['bri_pending'] is not None
        if pending:
            timeout = max(0.0, FRAME_S - (time.monotonic() - last_render))
        elif pg.name == 'settings':
            timeout = 0.5
        else:
            timeout = 5
        if mascot and mascot in pg.widgets \
                and mascot.next_deadline() is not None:
            # wake for the next sprite frame (talk/blink sprites, when the
            # mascot has them); render-on-dirty turns the tick into a
            # repaint (audit 6.5)
            timeout = min(timeout, max(
                0.0, mascot.next_deadline() - time.monotonic()))
        r, _, _ = select.select(list(devs), [], [], timeout)
        now = time.monotonic()
        if r:
            last_input = now
        elif not pending and now - last_input >= 5 \
                and len(set(devs.values())) < N_KINDS:
            # idle >=5 s and missing a device (e.g. touch daemon started
            # late): rescan so hot-(re)started devices get picked up
            close_inputs(devs)
            devs = open_inputs()
            last_input = now
            continue

        if mascot and mascot in pg.widgets:
            mascot.tick(now)

        if pg.name == 'settings':
            # sync the volume cache with changes made behind our back
            # (volume keys handled inside uart-hid-bridge, triggerhappy
            # mute): cheap tmpfs stat+read, no process spawn
            st = vol_state_read()
            if st and st[0] != state['vol_mtime']:
                state['vol_mtime'], state['vol'] = st
                pg.mark_values()

        clicked = False
        moved = False
        lost = False
        keys = []  # (code, value) presses/repeats from the grabbed keyboard
        for f in r:
            kind = devs[f]
            while True:  # drain everything queued on this fd
                try:
                    data = f.read(EVENT_SIZE)
                except OSError:
                    data = b''
                if data is None:        # EAGAIN - queue empty
                    break
                if len(data) < EVENT_SIZE:  # device went away (daemon restart)
                    lost = True
                    break
                t, code, v = unpack_event(data)
                if kind == 'kbd':
                    if t == EV_KEY and v in (1, 2):
                        keys.append((code, v))
                elif kind == 'mouse':
                    if t == EV_REL and code == REL_X:
                        cx += v
                        moved = True
                    elif t == EV_REL and code == REL_Y:
                        cy += v
                        moved = True
                    elif t == EV_KEY and code == BTN_LEFT:
                        if v == 1:
                            pend['mouse'] = True
                            held = True
                        else:
                            held = False
                    elif t == EV_SYN and pend['mouse']:
                        clicked = True
                        pend['mouse'] = False
                else:  # touch: act only on SYN so clicks use synced coords
                    if t == EV_ABS and code == ABS_X:
                        ax = v
                    elif t == EV_ABS and code == ABS_Y:
                        ay = v
                    elif t == EV_KEY and code == BTN_TOUCH:
                        if v == 1:
                            pend['touch'] = True
                            held = True
                        else:
                            held = False
                    elif t == EV_SYN:
                        if ax is not None and ay is not None:
                            cx, cy = ax, ay
                            moved = True
                        if pend['touch']:
                            clicked = True
                            pend['touch'] = False
        if lost:
            close_inputs(devs)
            devs = open_inputs()
            continue

        cx = max(0, min(scr.w - 1, cx))
        cy = max(0, min(scr.h - 1, cy))

        act = None
        if keys:
            if cursor_on:  # keyboard drives now: hide the cursor
                cursor_on = False
                cursor_dirty = True
            for code, val in keys:
                if val == 2 and code in NO_REPEAT:
                    continue  # no activation on autorepeat
                if router.intercept_key(code):
                    full = True  # bubble advanced/dismissed: repaint scene
                    continue
                a = page_key(pg, code)
                if a and act is None:
                    act = a  # one action per tick; later keys still navigate

        if clicked and router.intercept_click():
            clicked = False  # bubble advanced: click goes no further
            held = False
            full = True

        if moved or clicked:
            if not cursor_on:  # pointer motion brings the cursor back
                cursor_on = True
            cursor_dirty = True
            pg.pointer(cx, cy)
            w = pg.focused()
            # tap or drag consumed by the widget (slider scrubbing)
            if w and (clicked or held) and w.on_drag(cx, cy):
                clicked = False

        if clicked and act is None:
            w = pg.focused()
            act = w.on_click(cx, cy) if w else None

        if act:
            if 'push' in act:
                pg = router.push(act['push'])
                if pg.name == 'settings':
                    # one blocking read per entry; every redraw after this
                    # uses the cache (a VOL click costs 1 spawn, not 3).
                    # bit0-vol get also publishes the state file: snap its
                    # mtime so the poll doesn't immediately re-fire.
                    state['vol'] = get_volume()
                    st = vol_state_read()
                    if st:
                        state['vol_mtime'] = st[0]
                full = True
            elif 'pop' in act:
                if len(router.stack) > 1:  # ESC on the root page: no-op
                    pg = router.pop()
                    full = True
            elif 'cmd' in act:
                print(f'bit0-launcher: {act["msg"]}', flush=True)
                fullscreen_message(scr, act['msg'])
                for argv in act['cmd']:
                    subprocess.call(argv)
                time.sleep(60)  # init takes over from here
            elif 'act' in act:
                # in-page action (volume +/-): run it, then refresh the
                # widgets that render cache values
                try:
                    act['act']()
                except Exception as exc:
                    print(f'bit0-launcher: act: {exc}', flush=True)
                pg.mark_values()
            elif 'mascot' in act:
                d = act['mascot']
                save_selected(d['id'])
                mascot.set_definition(d)
                pg = router.pop()
                full = True
                mascot.say(['HI. I AM %s.' % d['name']]
                           + list(th.mascot_greeting))
            elif 'launch' in act:
                entry = act['launch']
                print(f'bit0-launcher: launching {entry["label"]}', flush=True)
                fullscreen_message(scr, 'LOADING...')
                close_inputs(devs)
                try:
                    launch_entry(entry, scr)
                except Exception as exc:
                    print(f'bit0-launcher: {entry["label"]}: {exc}', flush=True)
                devs = open_inputs()
                pg = router.reset()
                ax = ay = None
                full = True

        # Frame pacing: render when anything is dirty, but cap at ~30 fps
        # during pointer/drag/key floods; when select timed out (input
        # idle) or on an activation/page change, render immediately so the
        # final state never waits a frame.
        pg = router.page
        if full or cursor_dirty or pg.dirty_widgets() \
                or state['bri_pending'] is not None:
            if not r or clicked or act or full \
                    or (time.monotonic() - last_render) >= FRAME_S:
                render()


if __name__ == '__main__':
    main()
