#!/usr/bin/env python3
"""Bit-0 boot launcher.

Owns only: startup guards (singleton, SD release, stale-app cleanup),
page construction from the app registry + built-ins, and the input/render
event loop. Widgets/pages/router live in bit0.ui, drawing primitives in
bit0.fb, app launching in bit0.apps, the TOML registry in bit0.registry.

Rendering model (audit 6.2): the loop drains all pending input, updates
state (marking widgets dirty), then composes and flushes at most once per
tick (~30 fps, with a final render when input goes idle). Widgets never
flush themselves; control values (volume/brightness) come from a State
cache, never from sysfs/subprocess in the draw path.

Started at boot by bit0-launcher.service.
"""

import os
import sys
import fcntl
import select
import subprocess
import time

sys.path.insert(0, '/usr/local/lib')
from bit0.evdev import (EV_SYN, EV_KEY, EV_REL, EV_ABS,
                        REL_X, REL_Y, ABS_X, ABS_Y, BTN_LEFT, BTN_TOUCH,
                        EVENT_SIZE, unpack_event, find_event)
from bit0.fb import (Screen, fullscreen_message, GLYPH_H,
                     GEAR_ICON, BACK_ICON, C_TITLE, C_BLACK, C_WHITE)
from bit0.apps import (kill_stale, launch_entry, run_terminal, run_calibrate,
                       get_volume, vol_set, vol_state_read,
                       get_brightness, set_brightness)
from bit0.sdspi import run_sdcard, sd_release
from bit0.registry import load_apps
from bit0.ui.core import Page, Router
from bit0.ui.widgets import Button, LiveLabel, Slider, AppGrid, vstack, hstack

MOUSE_NAME = 'Lyra UART Mouse'
TOUCH_NAME = 'Lyra Touch Mouse'

FRAME_S = 0.033  # ~30 fps compose/flush cap (the SPI panel link is slow)


def open_inputs():
    """Returns {fd_object: kind} for the mouse and touch devices."""
    devs = {}
    for name, kind in ((MOUSE_NAME, 'mouse'), (TOUCH_NAME, 'touch')):
        path = find_event(name)
        if path:
            try:
                f = open(path, 'rb', buffering=0)
                os.set_blocking(f.fileno(), False)
                devs[f] = kind
            except OSError:
                pass
    return devs


def close_inputs(devs):
    for f in devs:
        try:
            f.close()
        except OSError:
            pass


def splash(scr):
    scr.fill_rect(0, 0, scr.w, scr.h, C_BLACK)
    s = 6
    tw = scr.text_width('Bit-0', s)
    scr.text('Bit-0', (scr.w - tw) // 2, (scr.h - GLYPH_H * s) // 2 - 14, s, C_WHITE)
    bar_y = (scr.h + GLYPH_H * s) // 2
    scr.fill_rect((scr.w - tw) // 2, bar_y, tw, 4, C_TITLE)
    scr.flush()
    time.sleep(2.2)


def build_pages(scr, state):
    """Main menu (registry-driven tile grid) + settings. Control widgets
    read/write the State cache, never sysfs/subprocess in the draw path."""

    def vol_step(d):
        base = state['vol'] if state['vol'] is not None else get_volume()
        # optimistic: vol_set returns the clamped pct; the helper runs
        # without blocking so the % label updates on the next frame
        state['vol'] = vol_set(base + d, wait=False)

    def vol_text():
        return '--' if state['vol'] is None else '%d%%' % state['vol']

    def bri_set(pct):
        # cache now; the render tick writes sysfs (at most once per frame)
        # and refreshes the cache with the clamped value before drawing
        state['bri_pending'] = pct

    # main menu: built-ins and TOML registry apps share one entry shape
    entries = [
        {'order': 10, 'label': 'TERMINAL', 'app': run_terminal},
        {'order': 90, 'label': 'SD CARD', 'app': (lambda: run_sdcard(scr))},
    ] + load_apps()
    entries.sort(key=lambda e: (e['order'], e['label']))
    grid = AppGrid(entries, x=6, y=40, w=scr.w - 12, h=scr.h - 50)
    gear = Button(icon=GEAR_ICON, action={'push': 'settings'},
                  x=scr.w - 36, y=6, w=30, h=26)
    main = Page('main', 'BIT-0', [grid, gear])

    slider = Slider('BRIGHTNESS', getter=(lambda: state['bri']),
                    setter=bri_set, x=24, y=46, w=scr.w - 48, h=24)
    volrow = hstack([Button('VOL -', action={'act': (lambda: vol_step(-10))}),
                     LiveLabel(vol_text),
                     Button('VOL +', action={'act': (lambda: vol_step(+10))})],
                    x=24, y=88, w=scr.w - 48, h=30, gap=8)
    col = vstack([
        Button('CALIBRATE',
               action={'launch': {'label': 'CALIBRATE', 'app': run_calibrate}}),
        Button('RESTART', action={'cmd': [['sync'], ['reboot']],
                                  'msg': 'RESTARTING...'}),
        Button('POWER OFF', action={'cmd': [['sync'], ['poweroff']],
                                    'msg': 'POWERING OFF'})],
        x=(scr.w - 260) // 2, w=260, top=128, bottom=scr.h - 10)
    back = Button(icon=BACK_ICON, action={'pop': True}, x=6, y=6, w=30, h=26)
    settings = Page('settings', 'SETTINGS', [slider] + volrow + col + [back])

    return {'main': main, 'settings': settings}


_lock = None  # must stay open for the process lifetime


def acquire_singleton():
    """Race-free single-instance guard via flock (PID scanning races when
    two respawn loops start children simultaneously - they mutually abort)."""
    global _lock
    _lock = open('/var/run/bit0-launcher.lock', 'w')
    try:
        fcntl.flock(_lock, fcntl.LOCK_EX | fcntl.LOCK_NB)
        return True
    except OSError:
        return False


def main():
    if not acquire_singleton():
        print('bit0-launcher: another instance is running, exiting', flush=True)
        sys.exit(0)
    # Keep the SPI SD card unbound by default so it doesn't poll the shared bus
    # and freeze the display; the SD CARD menu binds it on demand.
    sd_release()
    # Clear any app orphaned by a previous launcher restart still holding the
    # single-stream audio amp (would mute the next launch).
    kill_stale('pico8_dyn')
    # keep fbcon from blinking its cursor over our pixels
    try:
        with open('/sys/class/graphics/fbcon/cursor_blink', 'w') as f:
            f.write('0')
    except OSError:
        pass
    try:
        with open('/dev/tty1', 'w') as t:
            t.write('\033[?25l\033[2J')
    except OSError:
        pass

    scr = Screen()
    # splash only on the first start after boot (/tmp is tmpfs); respawns
    # and manual restarts go straight to the menu
    if not os.path.exists('/tmp/.bit0-splash-shown'):
        splash(scr)
        open('/tmp/.bit0-splash-shown', 'w').close()

    # Value cache: widgets draw from here, never from sysfs/subprocess.
    # vol is None until first read (on settings-page entry).
    state = {'vol': None, 'vol_mtime': None,
             'bri': get_brightness(), 'bri_pending': None}
    router = Router(build_pages(scr, state), root='main')

    cx, cy = scr.w // 2, scr.h // 2
    devs = open_inputs()
    print(f'bit0-launcher: inputs: {sorted(devs.values())}', flush=True)

    full = True           # full-page recompose pending
    cursor_dirty = False  # pointer moved since the last render
    last_render = 0.0
    scr._last_cur = (cx, cy)

    def render():
        """Single flush point per tick: apply deferred sysfs writes, compose
        dirty widgets, flush their rects (or the whole page), cursor last."""
        nonlocal full, cursor_dirty, last_render
        pg = router.page
        if state['bri_pending'] is not None:
            state['bri'] = set_brightness(state['bri_pending'])
            state['bri_pending'] = None
        if full:
            pg.compose(scr)
            scr.flush()  # full-frame flush covers the old cursor patch too
        else:
            scr.erase_cursor(*scr._last_cur)
            for i, w in enumerate(pg.widgets):
                if w.dirty:
                    w.draw(scr, i == pg.hover)
                    scr.flush(*w.flush_rect())
                    w.dirty = False
        scr.draw_cursor(cx, cy)
        scr._last_cur = (cx, cy)
        full = False
        cursor_dirty = False
        last_render = time.monotonic()

    render()

    ax = ay = None  # latest absolute touch sample
    pend = {'mouse': False, 'touch': False}  # button-down awaiting SYN
    held = False    # pointer button currently down (for slider drag)
    last_input = time.monotonic()
    while True:
        if not devs:  # nothing to read - retry discovery
            time.sleep(1)
            devs = open_inputs()
            continue

        # select timeout = next scheduled deadline: the remaining frame
        # budget when a render is pending; on the settings page a 0.5 s
        # poll of the bit0-vol state file (hotkey volume changes never
        # reach us as input events); else the 5 s rescan idle.
        pg = router.page
        pending = full or cursor_dirty or pg.dirty_widgets() \
            or state['bri_pending'] is not None
        if pending:
            timeout = max(0.0, FRAME_S - (time.monotonic() - last_render))
        elif pg.name == 'settings':
            timeout = 0.5
        else:
            timeout = 5
        r, _, _ = select.select(list(devs), [], [], timeout)
        now = time.monotonic()
        if r:
            last_input = now
        elif not pending and now - last_input >= 5 \
                and len(set(devs.values())) < 2:
            # idle >=5 s and missing a device (e.g. touch daemon started
            # late): rescan so hot-(re)started devices get picked up
            close_inputs(devs)
            devs = open_inputs()
            last_input = now
            continue

        if pg.name == 'settings':
            # sync the volume cache with changes made behind our back
            # (volume keys handled inside uart-hid-bridge, triggerhappy
            # mute): cheap tmpfs stat+read, no process spawn
            st = vol_state_read()
            if st and st[0] != state['vol_mtime']:
                state['vol_mtime'], state['vol'] = st
                pg.mark_values()

        clicked = False
        moved = False
        lost = False
        for f in r:
            kind = devs[f]
            while True:  # drain everything queued on this fd
                try:
                    data = f.read(EVENT_SIZE)
                except OSError:
                    data = b''
                if data is None:        # EAGAIN - queue empty
                    break
                if len(data) < EVENT_SIZE:  # device went away (daemon restart)
                    lost = True
                    break
                t, code, v = unpack_event(data)
                if kind == 'mouse':
                    if t == EV_REL and code == REL_X:
                        cx += v
                        moved = True
                    elif t == EV_REL and code == REL_Y:
                        cy += v
                        moved = True
                    elif t == EV_KEY and code == BTN_LEFT:
                        if v == 1:
                            pend['mouse'] = True
                            held = True
                        else:
                            held = False
                    elif t == EV_SYN and pend['mouse']:
                        clicked = True
                        pend['mouse'] = False
                else:  # touch: act only on SYN so clicks use synced coords
                    if t == EV_ABS and code == ABS_X:
                        ax = v
                    elif t == EV_ABS and code == ABS_Y:
                        ay = v
                    elif t == EV_KEY and code == BTN_TOUCH:
                        if v == 1:
                            pend['touch'] = True
                            held = True
                        else:
                            held = False
                    elif t == EV_SYN:
                        if ax is not None and ay is not None:
                            cx, cy = ax, ay
                            moved = True
                        if pend['touch']:
                            clicked = True
                            pend['touch'] = False
        if lost:
            close_inputs(devs)
            devs = open_inputs()
            continue

        cx = max(0, min(scr.w - 1, cx))
        cy = max(0, min(scr.h - 1, cy))

        if moved or clicked:
            cursor_dirty = True
            pg.pointer(cx, cy)
            w = pg.hovered()
            # tap or drag consumed by the widget (slider scrubbing)
            if w and (clicked or held) and w.on_drag(cx, cy):
                clicked = False

        if clicked:
            w = pg.hovered()
            act = (w.on_click(cx, cy) if w else None) or {}
            if 'push' in act:
                pg = router.push(act['push'])
                if pg.name == 'settings':
                    # one blocking read per entry; every redraw after this
                    # uses the cache (a VOL click costs 1 spawn, not 3).
                    # bit0-vol get also publishes the state file: snap its
                    # mtime so the poll doesn't immediately re-fire.
                    state['vol'] = get_volume()
                    st = vol_state_read()
                    if st:
                        state['vol_mtime'] = st[0]
                full = True
            elif 'pop' in act:
                pg = router.pop()
                full = True
            elif 'cmd' in act:
                print(f'bit0-launcher: {act["msg"]}', flush=True)
                fullscreen_message(scr, act['msg'])
                for argv in act['cmd']:
                    subprocess.call(argv)
                time.sleep(60)  # init takes over from here
            elif 'act' in act:
                # in-page action (volume +/-): run it, then refresh the
                # widgets that render cache values
                try:
                    act['act']()
                except Exception as exc:
                    print(f'bit0-launcher: act: {exc}', flush=True)
                pg.mark_values()
            elif 'launch' in act:
                entry = act['launch']
                print(f'bit0-launcher: launching {entry["label"]}', flush=True)
                fullscreen_message(scr, 'LOADING...')
                close_inputs(devs)
                try:
                    launch_entry(entry, scr)
                except Exception as exc:
                    print(f'bit0-launcher: {entry["label"]}: {exc}', flush=True)
                devs = open_inputs()
                pg = router.reset()
                ax = ay = None
                full = True

        # Frame pacing: render when anything is dirty, but cap at ~30 fps
        # during pointer/drag floods; when select timed out (input idle) or
        # on a click/page change, render immediately so the final state and
        # activations never wait a frame.
        pg = router.page
        if full or cursor_dirty or pg.dirty_widgets() \
                or state['bri_pending'] is not None:
            if not r or clicked or full \
                    or (time.monotonic() - last_render) >= FRAME_S:
                render()


if __name__ == '__main__':
    main()
