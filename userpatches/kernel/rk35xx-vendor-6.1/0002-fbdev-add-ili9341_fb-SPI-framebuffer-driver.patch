+static int ili9341_clear(struct ili9341_par *priv)
+{
+    u32 width = priv->display->xres;
+    u32 height = priv->display->yres;
+    u32 clear = 0x0;
+    int x, y;
+
+    printk("clearing screen(%d x %d) ...\n", width, height);
+
+    ili9341_set_addr_win(priv, 0, 0, width - 1, height - 1);
+
+    gpio_put(priv->gpio.dc, 1);
+    for (x = 0; x < width; x++)
+        for (y = 0; y < height; y++)
+            fbtft_write_spi_wr(priv, &clear, 2);
+
+    return 0;
+}
+
