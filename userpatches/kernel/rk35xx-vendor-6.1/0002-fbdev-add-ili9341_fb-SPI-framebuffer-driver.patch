From fca767b6a93e75a55839fe2325b98f21a425b6b8 Mon Sep 17 00:00:00 2001
From: pepe <jflira@miuandes.cl>
Date: Tue, 7 Jul 2026 18:57:57 -0400
Subject: [PATCH 2/3] fbdev: add ili9341_fb SPI framebuffer driver

Deferred-IO framebuffer driver for the ILI9341 TFT controller
(compatible "ilitek,ili9341"), with dirty-line tracking and optional
built-in splash screen (ILI9341_SPLASH). Imported from the Bit0
out-of-tree module; binds to the node added by the
rk3506g-luckfox-lyra-sd device tree.
---
 drivers/video/fbdev/Kconfig       |    21 +
 drivers/video/fbdev/Makefile      |     1 +
 drivers/video/fbdev/ili9341_fb.c  |  1100 +++
 drivers/video/fbdev/splash_data.h | 12803 ++++++++++++++++++++++++++++
 4 files changed, 13925 insertions(+)
 create mode 100644 drivers/video/fbdev/ili9341_fb.c
 create mode 100644 drivers/video/fbdev/splash_data.h

diff --git a/drivers/video/fbdev/Kconfig b/drivers/video/fbdev/Kconfig
index 37089d5..a7db422 100644
--- a/drivers/video/fbdev/Kconfig
+++ b/drivers/video/fbdev/Kconfig
@@ -2223,6 +2223,27 @@ config FB_SSD1307
 	  This driver implements support for the Solomon SSD1307
 	  OLED controller over I2C.
 
+config FB_ILI9341
+	tristate "Ilitek ILI9341 SPI framebuffer support"
+	depends on FB && SPI
+	depends on GPIOLIB || COMPILE_TEST
+	select FB_SYS_FOPS
+	select FB_SYS_FILLRECT
+	select FB_SYS_COPYAREA
+	select FB_SYS_IMAGEBLIT
+	select FB_DEFERRED_IO
+	help
+	  Framebuffer driver for the Ilitek ILI9341 320x240 TFT LCD
+	  controller attached over SPI, with deferred I/O and dirty-line
+	  tracking tuned for a shared SPI bus.
+
+config ILI9341_SPLASH
+	bool "ILI9341 embedded splash screen"
+	depends on FB_ILI9341
+	help
+	  Display a built-in splash image immediately when the ili9341_fb
+	  driver probes, before userspace starts.
+
 config FB_SM712
 	tristate "Silicon Motion SM712 framebuffer support"
 	depends on FB && PCI
