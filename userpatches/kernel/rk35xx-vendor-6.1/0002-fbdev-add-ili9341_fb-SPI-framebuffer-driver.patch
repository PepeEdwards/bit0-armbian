+    u32                     backlight_level;
+    u32                     backlight_max;
+    u32                     backlight_default;
+};
+
+#define ILI9341_BACKLIGHT_MAX 255
+#define ILI9341_BACKLIGHT_MIN 0
+
+static void ili9341_backlight_set(struct ili9341_par *par, u32 level)
+{
+    struct backlight_device *bl = par->backlight;
+
+    if (!par)
+        return;
+
+    if (!par->backlight_max)
+        par->backlight_max = ILI9341_BACKLIGHT_MAX;
+
+    level = min(level, par->backlight_max);
+
+    if (par->backlight_level != level) {
+        par->backlight_level = level;
+        #if IS_ENABLED(CONFIG_PWM)
+        if (par->backlight_pwm) {
+            struct pwm_state state;
+
+            pwm_init_state(par->backlight_pwm, &state);
+            if (!state.period)
+                state.period = 25000;
+
+            if (!level) {
+                state.enabled = false;
+                state.duty_cycle = 0;
+            } else {
+                u64 duty = (u64)state.period * level;
+
+                state.enabled = true;
+                state.duty_cycle = div_u64(duty, par->backlight_max);
+                if (!state.duty_cycle)
+                    state.duty_cycle = 1;
+            }
+
+            if (pwm_apply_state(par->backlight_pwm, &state))
+                dev_warn(par->dev, "failed to update backlight PWM duty\n");
+        }
+        #endif
+    }
+
+    if (par->gpio.backlight)
+        gpiod_set_value(par->gpio.backlight, level ? 1 : 0);
+
+    printk("backlight: level=%u\n", level);
+    printk("backlight: max=%u\n", par->backlight_max);
+    printk("backlight: default=%u\n", par->backlight_default);
+    printk("backlight: pwm=%p\n", par->backlight_pwm);
+    printk("backlight: gpio=%p\n", par->gpio.backlight);
+
+    if (bl) {
+        unsigned int brightness = clamp_t(unsigned int, level,
+                                        0,
+                                        bl->props.max_brightness);
+
+        bl->props.state = level ? 0 : BL_CORE_FBBLANK;
+        bl->props.power = level ? FB_BLANK_UNBLANK : FB_BLANK_POWERDOWN;
+        bl->props.brightness = brightness;
+        backlight_update_status(bl);
+    }
+}
+
+static int ili9341_backlight_init(struct ili9341_par *par)
+{
+    struct device *dev = par->dev;
+    struct device_node *np = dev->of_node;
+    struct device_node *bl_node;
+    int ret;
+
+    par->backlight_level = ILI9341_BACKLIGHT_MIN;
+    par->backlight_max = ILI9341_BACKLIGHT_MAX;
+    par->backlight_default = ILI9341_BACKLIGHT_MAX;
+
+    if (par->gpio.backlight) {
+        ili9341_backlight_set(par, par->backlight_default);
+        return 0;
+    }
+    else
+        dev_dbg(dev, "no backlight gpio\n");
+
+    if (ret == -EPROBE_DEFER)
+        return ret;
+    if (ret && ret != -ENOENT && ret != -ENODEV && ret != -EINVAL)
+        return ret;
+  
+    par->gpio.backlight = NULL;
+
+    par->backlight = devm_of_find_backlight(dev);
+    if (!IS_ERR(par->backlight)) {
+        par->backlight_default = min_t(u32, par->backlight_default, par->backlight->props.max_brightness);
+        ili9341_backlight_set(par, par->backlight_default);
+        return 0;
+    }
+  
+    ret = PTR_ERR(par->backlight);
+    if (ret == -EPROBE_DEFER)
+        return ret;
+    par->backlight = NULL;
+  
+    #if IS_ENABLED(CONFIG_PWM)
+        struct fwnode_handle *fwnode;
+        bl_node = of_parse_phandle(np, "backlight", 0);
+        if (!bl_node)
+            return 0;
+
+        fwnode = of_fwnode_handle(bl_node);
+        par->backlight_pwm = devm_fwnode_pwm_get(dev, fwnode, NULL);
+        of_node_put(bl_node);
+        if (IS_ERR(par->backlight_pwm)) {
+            ret = PTR_ERR(par->backlight_pwm);
+            par->backlight_pwm = NULL;
+            if (ret == -EPROBE_DEFER)
+                return ret;
+            if (ret != -ENOENT && ret != -ENODEV)
+                dev_err(dev, "failed to request backlight PWM: %d\n", ret);
+            return ret;
+        }
+
+        ili9341_backlight_set(par, par->backlight_default);
+    #endif
+    return 0;
+  }
