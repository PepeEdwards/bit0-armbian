+#define gpio_put(d, v) gpiod_set_value(d, v)
+int fbtft_write_spi_wr(struct ili9341_par *par, void *buf, size_t len)
+{
+    int rc;
+    rc = spi_write(par->spi, buf, len);
+
+    return rc;
+}
+
+/*
+int fbtft_write_gpio16_wr(struct ili9341_par *par, void *buf, size_t len)
+*/
+static inline void fbtft_write_buf_dc(struct ili9341_par *par, void *buf, size_t len, int dc)
+{
+    gpio_put(par->gpio.dc, dc);
+    fbtft_write_spi_wr(par, buf, len);
+}
+
+#define NUMARGS(...)  (sizeof((int[]){__VA_ARGS__}) / sizeof(int))
+static int ili9341_write_reg(struct ili9341_par *par, int len, ...)
+{
+    u8 *buf = (u8 *)par->buf;
+    va_list args;
+    int i;
+
+    va_start(args, len);
+
+    *buf = (u8)va_arg(args, unsigned int);
+    fbtft_write_buf_dc(par, buf, sizeof(u8), 0);
+    len--;
+
+    /* if there no params */
+    if (len == 0)
+        goto exit_no_param;
+
+    for (i = 0; i < len; i++)
+        *buf++ = (u8)va_arg(args, unsigned int);
+
+    fbtft_write_buf_dc(par, par->buf, len, 1);
+    va_end(args);
+
+exit_no_param:
+    va_end(args);
+    return 0;
+}
+#define write_reg(par, ...) \
+    ili9341_write_reg(par, NUMARGS(__VA_ARGS__), __VA_ARGS__)
+
+static int ili9341_reset(struct ili9341_par *par)
+{
+    gpio_put(par->gpio.rst, 1);
+    mdelay(10);
+    gpio_put(par->gpio.rst, 0);
+    mdelay(10);
+    gpio_put(par->gpio.rst, 1);
+    mdelay(10);
+    return 0;
+}
+
+static int ili9341_init_display(struct ili9341_par *priv)
+{
+    bool invert_colors;
+    
+    ili9341_reset(priv);
+
+    write_reg(priv,0x01); /* Software Reset */
+    mdelay(120);  /* ILI9341 needs ~120ms after reset, not 2 seconds */
+    write_reg(priv,0x28); /*Display OFF*/
+    write_reg(priv,0xCB, 0x39, 0x2C, 0x00, 0x34, 0x02); /*Power Control A*/
+    write_reg(priv,0xCF, 0x00, 0xC1, 0x30); /*Power Control B*/
+    write_reg(priv,0xE8, 0x85, 0x00, 0x78); /*Driver Timing Control A*/
+    write_reg(priv,0xEA, 0x00, 0x00); /*Driver Timing Control B*/
+    write_reg(priv,0xED, 0x64, 0x03, 0x12, 0x81); /*Power On Sequence Control*/
+
+    write_reg(priv, 0x26, 0x01);          // Gamma Set
+    // Positive Gamma Control
+    write_reg(priv, 0xE0, 0x0F, 0x31, 0x2B, 0x0C, 0x0E, 0x08, 0x4E, 0xF1, 0x37, 0x07, 0x10, 0x03, 0x0E, 0x09, 0x00);
+    // Negative Gamma Control
+    write_reg(priv, 0xE1, 0x00, 0x0E, 0x14, 0x03, 0x11, 0x07, 0x31, 0xC1, 0x48, 0x08, 0x0F, 0x0C, 0x31, 0x36, 0x0F);
+
+    write_reg(priv, 0xC0, 0x23);                // Power Control 1
+    write_reg(priv, 0xC1, 0x10);                // Power Control 2
+    write_reg(priv, 0xC5, 0x45, 0x15);          // VCOM Control - adjusted for better contrast
+    write_reg(priv, 0xC7, 0x90);                // VCOM Offset - fine-tune contrast
+
+    write_reg(priv, 0x3A, 0x55);                // Pixel Interface Format  16 bit colour for SPI
+
+    // Frame Rate Control
+    // write_reg(priv, 0xB1, 0xA0);
+    // write_reg(priv, 0xB1, 0x00);             // 60Hz
+    write_reg(priv, 0xB1, 0x00, 0x1B);          // ~79Hz;
+    /* Check for display inversion property */
+    invert_colors = device_property_present(priv->dev, "invert-colors");
+    if (invert_colors)
+        write_reg(priv, 0x21); /* TFT_INVON - Invert colors */
+    else
+        write_reg(priv, 0x20); /* TFT_INVOFF - Normal colors */
+
+    write_reg(priv, 0xB6, 0x08, 0x82, 0x27);    // Display Function Control
+    write_reg(priv, 0x11);                      // Exit Sleep
+    mdelay(120);
+
+    write_reg(priv, 0x29);                      // Display on
+    mdelay(20);
+    /*
+    write_reg(priv, 0x36);
+    write_reg(priv, 0x36, 0x01, 0x48);
+    */
+
+    return 0;
+}
+
+static int ili9341_blank(struct ili9341_par *par, bool on)
+{
+    if (on)
+        write_reg(par, MIPI_DCS_SET_DISPLAY_OFF);
+    else
+        write_reg(par, MIPI_DCS_SET_DISPLAY_ON);
+    ili9341_backlight_set(par, on ? ILI9341_BACKLIGHT_MIN : par->backlight_default);
+    return 0;
+}
+
+static int ili9341_set_addr_win(struct ili9341_par *par, int xs, int ys, int xe,
+                                int ye)
+{
+    const u32 xres = par->fbinfo->var.xres, yres = par->fbinfo->var.yres;
+    WARN_ON_ONCE(xs < 0 || ys < 0 || xe < 0 || ye < 0);
+    WARN_ON_ONCE(xs > xe || ys > ye);
+    WARN_ON_ONCE(xe >= xres || ye >= yres);   /* inclusive end */
+
+    dev_dbg(par->dev, "xs = %d, xe = %d, ys = %d, ye = %d\n", xs, xe, ys, ye);
+
+    write_reg(par, 0x2A,
+              ((xs >> BITS_PER_BYTE)), (xs & 0xFF),
+              ((xe >> BITS_PER_BYTE)), (xe & 0xFF));
+
+    write_reg(par, 0x2B,
+              ((ys >> BITS_PER_BYTE)), (ys & 0xFF),
+              ((ye >> BITS_PER_BYTE)), (ye & 0xFF));
+
+    write_reg(par, 0x2C);
+
+    return 0;
+}
