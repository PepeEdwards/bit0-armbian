From a9ca059b9b6eb3051b446f989c3bb1dac213ed3e Mon Sep 17 00:00:00 2001
From: pepe <jflira@miuandes.cl>
Date: Tue, 7 Jul 2026 23:47:55 -0400
Subject: [PATCH 1/2] ARM: dts: rockchip: add rk3506g-luckfox-lyra-sd (Bit0
 handheld)

Base Luckfox Lyra board booting from SD, configured as the Bit0
handheld: ILI9341 SPI display via the mainline panel-mipi-dbi driver
(init sequence in firmware file bit0,ili9341.bin), TSC2046 touch and
SD-over-SPI sharing SPI0, MAX98357A on SAI0, QMK keyboard bridge on
UART2. Stock DSI panel and its I2C touch controllers are disabled.

The display backlight reuses the dtsi's pwm-backlight (pwm0 ch2 on
rm_io15/GPIO1_B2) rather than a new node: same-named root nodes merge
and inherit the dtsi's status=disabled.
---
 arch/arm/boot/dts/Makefile                    |   1 +
 arch/arm/boot/dts/rk3506g-luckfox-lyra-sd.dts | 251 ++++++++++++++++++
 2 files changed, 252 insertions(+)
 create mode 100644 arch/arm/boot/dts/rk3506g-luckfox-lyra-sd.dts

diff --git a/arch/arm/boot/dts/Makefile b/arch/arm/boot/dts/Makefile
index ffd7467..f717125 100644
--- a/arch/arm/boot/dts/Makefile
+++ b/arch/arm/boot/dts/Makefile
@@ -1243,6 +1243,7 @@ dtb-$(CONFIG_ARCH_ROCKCHIP) += \
 	rk3506g-evb1-v10-sii9022-rgb2hdmi.dtb \
 	rk3506g-evb2-v10.dtb \
 	rk3506g-luckfox-lyra-plus-sd.dtb \
+	rk3506g-luckfox-lyra-sd.dtb \
 	rk3506g-iotest-v10.dtb \
 	rk3506g-iotest-v10-pdm.dtb \
 	rk3506g-test1-v10-audio.dtb \
diff --git a/arch/arm/boot/dts/rk3506g-luckfox-lyra-sd.dts b/arch/arm/boot/dts/rk3506g-luckfox-lyra-sd.dts
new file mode 100644
index 0000000..aa8e6c8
--- /dev/null
+++ b/arch/arm/boot/dts/rk3506g-luckfox-lyra-sd.dts
@@ -0,0 +1,251 @@
+// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
+/*
+ * Copyright (c) 2024 Rockchip Electronics Co., Ltd.
+ *
+ * Luckfox Lyra (base board, SD boot) — Bit0 handheld configuration:
+ * ILI9341 SPI display (panel-mipi-dbi, init sequence in firmware file
+ * bit0,ili9341.bin) + TSC2046 touch + SD-over-SPI on a shared SPI0 bus,
+ * MAX98357A speaker amp on SAI0, QMK keyboard bridge on UART2.
+ * The stock MIPI-DSI panel and its I2C touch controllers are disabled.
+ */
+
+/dts-v1/;
+
+#include "rk3506-luckfox-lyra.dtsi"
+
+/ {
+	model = "Luckfox Lyra";
+	compatible = "rockchip,rk3506g-demo-display-control", "rockchip,rk3506";
+
+	chosen {
+		bootargs = "earlycon=uart8250,mmio32,0xff0a0000 console=tty1 console=tty2 console=ttyFIQ0 fbcon=font:VGA8x8 storagemedia=sd root=/dev/mmcblk0p3 rootfstype=ext4 rootwait snd_aloop.index=7 snd_aloop.use_raw_jiffies=1";
+	};
+
+	max98357a: max98357a-codec {
+		compatible = "maxim,max98357a";
+		#sound-dai-cells = <0>;
+	};
+
+	sound {
+		compatible = "simple-audio-card";
+		simple-audio-card,name = "Lyra MAX98357A";
+		simple-audio-card,format = "i2s";
+		simple-audio-card,bitclock-master = <&sai0_cpu>;
+		simple-audio-card,frame-master = <&sai0_cpu>;
+		simple-audio-card,mclk-fs = <256>;
+		simple-audio-card,widgets =
+			"Speaker", "External Speaker";
+		simple-audio-card,routing =
+			"External Speaker", "Speaker";
+
+		sai0_cpu: simple-audio-card,cpu {
+			sound-dai = <&sai0>;
+		};
+
+		simple-audio-card,codec {
+			sound-dai = <&max98357a>;
+		};
+	};
+};
+
+/**********display**********/
+
+/*
+ * The dtsi already carries a pwm-backlight ("backlight" node, disabled)
+ * wired to pwm0 ch2 on rm_io15 = GPIO1_B2 — exactly the Bit0's backlight
+ * pin. Enable it instead of adding our own node: same-named root nodes
+ * merge in dtc, and a duplicate "backlight" node inherits the dtsi's
+ * status="disabled" (learned the hard way). Bonus: real brightness
+ * control via /sys/class/backlight.
+ */
+&backlight {
+	status = "okay";
+};
+
+&cma {
+	size = <0x1000000>;
+};
+
+&dsi {
+	status = "disabled";
+};
+
+&dsi_dphy {
+	status = "disabled";
+};
+
+&dsi_in_vop {
+	status = "disabled";
+};
+
+&route_dsi {
+	status = "disabled";
+};
+
+/*
+ * The stock I2C touch controllers (GT9271/GT911/FT5406) and the Waveshare
+ * DSI backlight live on i2c2 in the dtsi; nothing else uses the bus here.
+ */
+&i2c2 {
+	status = "disabled";
+};
+
+&spi0 {
+	status = "okay";
+	pinctrl-names = "default";
+	pinctrl-0 = <&rm_io29_spi0_clk &rm_io28_spi0_mosi &rm_io31_spi0_miso>;
+	cs-gpios = <&gpio1 RK_PD2 GPIO_ACTIVE_LOW>,	/* display CS - rm_io30 */
+		   <&gpio0 RK_PB5 GPIO_ACTIVE_LOW>,	/* touch CS - GPIO0_B5 */
+		   <&gpio0 RK_PA2 GPIO_ACTIVE_LOW>;	/* SD card CS - GPIO0_A2 */
+
+	display: display@0 {
+		/*
+		 * Mainline generic MIPI-DBI panel driver. The controller init
+		 * sequence (gamma, VCOM, 16bpp pixel format, inversion ON)
+		 * comes from /lib/firmware/bit0,ili9341.bin — see
+		 * scripts/panel-firmware/ in the bit0-armbian repo.
+		 */
+		compatible = "bit0,ili9341", "panel-mipi-dbi-spi";
+		reg = <0>;
+		pinctrl-names = "default";
+		pinctrl-0 = <&ili9341_pins>;
+		spi-max-frequency = <80000000>;
+		dc-gpios = <&gpio1 RK_PC2 GPIO_ACTIVE_HIGH>;	/* rm_io27 */
+		reset-gpios = <&gpio1 RK_PB3 GPIO_ACTIVE_HIGH>;	/* rm_io26 */
+		backlight = <&backlight>;
+
+		/* 2.8" module glass; only affects reported DPI */
+		width-mm = <43>;
+		height-mm = <58>;
+
+		panel-timing {
+			hactive = <240>;
+			vactive = <320>;
+			hback-porch = <0>;
+			vback-porch = <0>;
+			clock-frequency = <0>;
+			hfront-porch = <0>;
+			hsync-len = <0>;
+			vfront-porch = <0>;
+			vsync-len = <0>;
+		};
+	};
+
+	touch: touch@1 {
+		compatible = "ti,tsc2046";
+		reg = <1>;
+		spi-max-frequency = <2000000>;
+		pinctrl-names = "default";
+		pinctrl-0 = <&touch_pins>;
+
+		interrupt-parent = <&gpio0>;
+		interrupts = <RK_PA4 IRQ_TYPE_EDGE_FALLING>;
+		pendown-gpio = <&gpio0 RK_PA4 GPIO_ACTIVE_LOW>;
+
+		/* Raw 12-bit output only. Coordinate transformation (swap/invert/
+		 * scale) is done in userspace by /usr/bin/touch-mouse using the
+		 * affine calibration from touch-cal (/etc/touch-mouse.cal).
+		 * Do NOT add touchscreen-size-x/y or touchscreen-swapped-x-y here:
+		 * combined with ti,*-min/max they corrupt the advertised abs
+		 * ranges (measured: X claimed 163..239, values ran 300..3900). */
+		ti,x-min = /bits/ 16 <302>;
+		ti,x-max = /bits/ 16 <3919>;
+		ti,y-min = /bits/ 16 <163>;
+		ti,y-max = /bits/ 16 <3839>;
+		ti,x-plate-ohms = /bits/ 16 <60>;
+		ti,pressure-max = /bits/ 16 <160>;
+
+		/* Stability settings, relaxed for latency: fewer resamples per
+		 * point, since every touch SPI transaction queues behind ~15 ms
+		 * display blits on the shared bus. */
+		ti,debounce-max = /bits/ 16 <5>;
+		ti,debounce-tol = /bits/ 16 <60>;
+		ti,debounce-rep = /bits/ 16 <1>;
+
+		wakeup-source;
+	};
+
+	mmc_spi: mmc@2 {
+		compatible = "mmc-spi-slot";
+		reg = <2>;
+		spi-max-frequency = <20000000>;	/* reduced from 25MHz to minimize bus conflicts */
+		voltage-ranges = <3300 3300>;
+
+		/*
+		 * Enabled so the spi0.2 device exists, but the bit-0 launcher
+		 * unbinds mmc_spi at startup (and after each SD read) so it does
+		 * NOT poll the shared spi0 bus - polling here stalled the bus with
+		 * -110 timeouts and froze the display. The SD CARD menu binds it
+		 * on demand to read a cartridge, then unbinds to free the bus.
+		 */
+		status = "okay";
+
+		broken-cd;	/* no card detect, rely on manual detection */
+	};
+};
+
+/**********uart keyboard**********/
+&uart2 {
+	status = "okay";
+	pinctrl-names = "default";
+	pinctrl-0 = <&rm_io8_uart2_tx &rm_io9_uart2_rx>;
+};
+
+/**********audio**********/
+&sai0 {
+	status = "okay";
+	pinctrl-names = "default";
+	pinctrl-0 = <&sai0_lrck_pins &sai0_sclk_pins &sai0_sdo_pins>;
+	assigned-clocks = <&cru MCLK_SAI0>;
+	assigned-clock-rates = <12288000>;
+	#sound-dai-cells = <0>;
+};
+
+&sai1 {
+	status = "disabled";
+};
+
+&sai3 {
+	status = "disabled";
+};
+
+/**********ethernet**********/
+&gmac1 {
+	status = "disabled";
+};
+
+&mdio1 {
+	status = "disabled";
+};
+
+/**********usb**********/
+&usb20_otg0 {
+	dr_mode = "peripheral";
+	status = "okay";
+};
+
+&usb20_otg1 {
+	dr_mode = "host";
+	status = "okay";
+};
+
+/**********pinctrl**********/
+&pinctrl {
+	ili9341 {
+		ili9341_pins: ili9341-pins {
+			/* RST + DC only; the backlight pin (GPIO1_B2/rm_io15) is
+			 * muxed to pwm0_ch2 by the dtsi's pwm0_4ch_2 pinctrl. */
+			rockchip,pins =
+				<1 RK_PB3 RK_FUNC_GPIO &pcfg_pull_none>,
+				<1 RK_PC2 RK_FUNC_GPIO &pcfg_pull_none>;
+		};
+	};
+
+	touch {
+		touch_pins: touch-pins {
+			rockchip,pins =
+				<0 RK_PB5 RK_FUNC_GPIO &pcfg_pull_up>,	/* CS */
+				<0 RK_PA4 RK_FUNC_GPIO &pcfg_pull_up>;	/* IRQ */
+		};
+	};
+};
-- 
2.34.1

